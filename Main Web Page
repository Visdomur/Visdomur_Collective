// Carousel logic
let carouselInterval = null;
function renderCarousel() {
  const wrap = document.getElementById('disp-carousel');
  const slides = profileData.carouselSlides;
  if (!slides.length) { wrap.innerHTML = ''; return; }
  wrap.innerHTML = slides.map((s, i) =>
    `<div class="carousel-slide${i===0?' active':''}" style="background-color:${profileData.imgBorderColor}; background-image:url('${s.img}')">
      <div class="slide-label">${escHtml(s.label)}</div>
      <div class="slide-inner" style="background-image:url('${s.img}')">
        <a href="${s.link||'#'}" style="display:block;width:100%;height:100%"></a>
      </div>
    </div>`
  ).join('');
  if (carouselInterval) clearInterval(carouselInterval);
  let idx = 0;
  carouselInterval = setInterval(() => {
    const sl = wrap.querySelectorAll('.carousel-slide');
    sl.forEach(s => s.classList.remove('active'));
    idx = (idx + 1) % sl.length;
    sl[idx].classList.add('active');
  }, 4000);
}

