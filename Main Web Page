// ===== APPLY DATA TO VIEWER =====
function applyToViewer() {
  // CSS vars
  const hex = profileData.accentColor;
  const rgb = hexToRgb(hex);
  document.documentElement.style.setProperty('--color-accent', hex);
  document.documentElement.style.setProperty('--color-accent-rgb', `${rgb.r}, ${rgb.g}, ${rgb.b}`);
  document.documentElement.style.setProperty('--color-bg', profileData.bgColor);
  document.documentElement.style.setProperty('--color-text', profileData.textColor);
  document.documentElement.style.setProperty('--color-scrollbox', profileData.cardColor);
  document.documentElement.style.setProperty('--color-img-border', profileData.imgBorderColor);
  document.documentElement.style.setProperty('--font-body', profileData.fontBody);
  document.documentElement.style.setProperty('--font-display', profileData.fontDisplay);

  // Nav title
  document.getElementById('nav-site-title').textContent = profileData.siteTitle;
  document.getElementById('page-title').textContent = profileData.siteTitle;

  // Banner
  const banner = document.getElementById('profile-banner');
  if (profileData.bannerImg) {
    banner.style.backgroundImage = `url('${profileData.bannerImg}')`;
    banner.classList.remove('no-image');
  } else {
    banner.style.backgroundImage = '';
    banner.classList.add('no-image');
  }
  banner.style.backgroundColor = profileData.bgColor;

  // Profile outer background
  const outer = document.getElementById('profile-outer-bg');
  const bgImg = profileData.bgImg ? ` url('${profileData.bgImg}')` : '';
  outer.style.background = profileData.bgColor + bgImg;

  // Username
  document.getElementById('disp-username').textContent = profileData.username;

  // Pagedoll
