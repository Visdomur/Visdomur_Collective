<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title id="page-title">My Profile</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Andale+Mono&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root {
    --color-text: #0f0f0f;
    --color-scrollbox: #fbfbfb;
    --color-accent: #d94a79;
    --color-accent-rgb: 217, 74, 121;
    --color-bg: #ffd9e5;
    --color-img-border: #4c4c4c;
    --font-body: 'Andale Mono', monospace;
    --font-display: Impact, sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font-body);
    background: #1a1a1a;
    min-height: 100vh;
  }

  /* ===== VIEWER MODE ===== */
  #viewer-mode { display: block; }
  #creator-mode { display: none; }

  /* Site wrapper shown in viewer */
  .site-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Banner */
  .profile-banner {
    width: 100%;
    height: 220px;
    background: var(--color-bg) url('') center/cover no-repeat;
    border-radius: 0 0 20px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .profile-banner.no-image::after {
    content: '[ profile banner ]';
    color: rgba(255,255,255,0.4);
    font-family: var(--font-body);
    font-size: 14px;
    letter-spacing: 3px;
  }

  /* Nav bar */
  .site-nav {
    background: #111;
    padding: 10px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .site-nav .nav-title {
    color: #fff;
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 4px;
    text-transform: uppercase;
  }
  .site-nav .nav-links {
    display: flex;
    gap: 12px;
  }
  .nav-btn {
    padding: 6px 18px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    color: #fff;
    font-family: var(--font-body);
    font-size: 13px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .nav-btn:hover, .nav-btn.active {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.5);
  }
  .nav-btn.creator-trigger {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .nav-btn.creator-trigger:hover {
    background: rgba(var(--color-accent-rgb), 0.15);
  }

  /* Main content area */
  .main-content {
    flex: 1;
    padding: 20px 16px 40px;
  }

  /* ===== PROFILE CARD ===== */
  .profile-outer {
    background: var(--color-bg) url('') center/cover;
    border-radius: 20px;
    padding: 20px 0 0;
    max-width: 1100px;
    margin: 0 auto;
  }

  .content-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding: 0 16px;
  }

  /* Left column */
  .left-col {
    width: 300px;
    flex-shrink: 0;
    padding: 0 8px 12px;
    margin: 0 auto 12px;
    position: relative;
  }
  .left-inner {
    height: 500px;
    background: var(--color-scrollbox);
    border-radius: 20px;
    box-shadow: 4px 4px 0px rgba(var(--color-accent-rgb), 0.5);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: visible;
  }
  .left-icon-decor {
    position: absolute;
    top: -20px;
    left: -25px;
    font-size: 60px;
    color: var(--color-text);
    text-shadow: 3px 3px 0 var(--color-accent);
    z-index: 5;
  }
  .left-username {
    color: var(--color-scrollbox);
    letter-spacing: 7px;
    font-size: 40px;
    text-shadow: -1px -1px 0 var(--color-accent), 3px -1px 0 var(--color-accent), -1px 1px 0 var(--color-text), 3px 3px 0 var(--color-text);
    font-family: var(--font-display);
    font-weight: bold;
    text-transform: uppercase;
    position: absolute;
    top: -20px;
    left: 0;
    z-index: 10;
    line-height: 1;
  }
  .left-pagedoll {
    position: absolute;
    right: -10px;
    top: -30px;
    z-index: 11;
    filter: drop-shadow(4px 2px var(--color-text));
  }
  .left-pagedoll img { width: 130px; display: block; }
  .focal-image {
    background: url('') center/cover no-repeat var(--color-accent);
    border-radius: 20px 20px 0 200px;
    flex: 1;
    opacity: 0.8;
  }
  .focal-image.placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 2px;
  }
  .left-info {
    padding: 8px 10px;
    text-transform: uppercase;
    font-weight: bold;
    text-align: right;
    color: var(--color-text);
    font-size: 13px;
  }
  .icon-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 4px;
    margin-top: 4px;
  }
  .icon-links a {
    color: var(--color-text);
    text-decoration: none;
    margin: 0 4px;
    font-size: 15px;
    transition: color 0.2s;
  }
  .icon-links a:hover { color: var(--color-accent); }

  /* Right column */
  .right-col {
    flex: 1;
    min-width: 0;
    padding: 0 8px 12px;
  }
  .right-inner {
    height: 500px;
    background: var(--color-scrollbox);
    border-radius: 20px;
    box-shadow: 4px 4px 0px rgba(var(--color-accent-rgb), 0.5);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }
  .scroll-icon {
    position: absolute;
    bottom: -5px;
    right: -10px;
    font-size: 30px;
    z-index: 20;
    color: var(--color-text);
    text-shadow: 2px 2px var(--color-accent);
    pointer-events: none;
  }

  /* Music bar */
  .music-bar {
    background: var(--color-text);
    color: var(--color-scrollbox);
    border-radius: 20px 20px 0 0;
    padding: 6px 16px;
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-transform: uppercase;
    position: relative;
    cursor: pointer;
  }
  .music-bar iframe {
    height: 300px;
    width: 2.5rem;
    opacity: 0.0001;
    position: absolute;
    left: 0;
    top: -130px;
    border: none;
  }

  /* Scrollbox */
  .scrollbox {
    overflow-y: auto;
    flex: 1;
    scrollbar-width: none;
  }
  .scrollbox::-webkit-scrollbar { display: none; }

  /* Section header */
  .section-header {
    display: inline-block;
    text-transform: uppercase;
    padding: 4px 10px;
    margin: 12px 0;
    letter-spacing: 7px;
    font-size: 30px;
    font-family: var(--font-display);
    background: var(--color-accent);
    color: var(--color-scrollbox);
    box-shadow: 3px 3px 0 var(--color-text), 0 4px 0 var(--color-text);
    border-radius: 0 20px 20px 0;
  }

  /* Notices */
  .notices-section {
    padding: 0 12px;
    word-break: normal;
    overflow-wrap: normal;
  }
  .notices-section ul {
    list-style: square;
    padding-left: 20px;
    padding-right: 12px;
  }
  .notices-section ul li { margin-bottom: 4px; }
  .notices-section a { color: var(--color-accent); }
  .pagedoll-float-right {
    float: right;
    padding: 0 4px;
    margin-top: -20px;
  }
  .pagedoll-float-right img, .pagedoll-float-left img { max-height: 200px; }
  .pagedoll-float-left { float: left; padding: 0 4px; }

  /* Status + Carousel row */
  .status-carousel-row {
    display: flex;
    flex-wrap: wrap;
    padding: 12px 0 0;
    clear: both;
  }
  .art-status { padding: 0 12px; }
  .status-line {
    display: flex;
    align-items: center;
    margin-bottom: 4px;
    font-size: 13px;
  }
  .status-label {
    background: var(--color-text);
    color: var(--color-scrollbox);
    font-weight: bold;
    text-transform: uppercase;
    padding: 1px 8px;
    font-size: 12px;
    white-space: nowrap;
  }
  .status-value {
    padding: 0 8px;
    font-size: 12px;
  }
  .status-value a { color: var(--color-text); }

  /* Carousel */
  .carousel-wrap {
    flex: 1;
    min-width: 200px;
    min-height: 200px;
    margin: 0 8px 0 12px;
    position: relative;
    border-radius: 20px 0 0 20px;
    overflow: hidden;
  }
  .carousel-inner { width: 100%; height: 100%; position: relative; }
  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease;
    background: var(--color-img-border) center/cover no-repeat;
    background-blend-mode: screen;
    border-radius: 20px 0 0 20px;
    display: flex;
    align-items: flex-start;
    padding: 8px 0 0 16px;
  }
  .carousel-slide.active { opacity: 1; }
  .slide-inner {
    position: absolute;
    inset: 8px 0 8px 8px;
    border-left: 1px dashed #fbfbfb;
    border-top: 1px dashed #fbfbfb;
    border-bottom: 1px dashed #fbfbfb;
    border-radius: 20px 0 0 20px;
    background: center/cover no-repeat;
  }
  .slide-label {
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 7px;
    font-size: 26px;
    mix-blend-mode: screen;
    text-shadow: -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 1px 1px 0 #fff;
    font-family: var(--font-display);
    z-index: 2;
    position: relative;
    margin-top: 4px;
  }

  /* About section */
  .about-section {
    padding: 0 12px;
    word-break: normal;
    overflow-wrap: normal;
    clear: both;
  }
  .about-section p { margin-bottom: 8px; line-height: 1.6; font-size: 13px; }

  /* Interests */
  .interests-section { padding: 0 8px; }
  .interest-block { margin: 8px 0; font-size: 13px; }
  .interest-label {
    display: inline-block;
    background: var(--color-text);
    color: var(--color-scrollbox);
    font-weight: bold;
    text-transform: uppercase;
    padding: 1px 8px;
    margin-left: -8px;
    font-size: 12px;
  }

  /* Ribbons */
  .ribbons-section { padding: 8px; }
  .ribbons-row { display: flex; flex-wrap: wrap; gap: 4px; padding: 8px; }
  .ribbon-item img {
    height: 62px;
    display: block;
    transition: transform 0.2s;
  }
  .ribbon-item img:hover { transform: scale(1.05); }

  /* Favorites */
  .favorites-section { padding: 0 8px 12px; }
  .fav-block { font-size: 13px; margin-bottom: 4px; }
  .fav-label {
    display: inline-block;
    background: var(--color-text);
    color: var(--color-scrollbox);
    font-weight: bold;
    text-transform: uppercase;
    padding: 1px 8px;
    font-size: 12px;
  }
  .fav-label i { font-size: 11px; margin-right: 3px; }

  /* Fav Characters */
  .fav-chars {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    color: var(--color-scrollbox);
    clear: both;
    padding: 8px;
  }
  .fav-char-card {
    margin: 4px;
    background: var(--color-text);
    border-radius: 20px;
    height: 140px;
    width: 140px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .fav-char-img {
    flex: 1;
    background: var(--color-accent) center/cover no-repeat;
    border-radius: 20px 20px 0 0;
    border: 3px solid var(--color-text);
    border-bottom: none;
  }
  .fav-char-name {
    text-align: center;
    text-transform: uppercase;
    padding: 4px 12px;
    font-size: 11px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #fff;
  }

  /* Featured characters row */
  .featured-chars {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 16px 20px;
  }
  .featured-char {
    margin: 4px;
    padding: 8px;
    background: var(--color-scrollbox);
    border-radius: 20px;
    box-shadow: 4px 4px 0 rgba(var(--color-accent-rgb), 0.5);
    position: relative;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .featured-char:hover { transform: translateY(-2px); }
  .featured-char-img {
    background: var(--color-accent) center/cover no-repeat;
    height: 150px;
    width: 150px;
    border-radius: 20px;
  }
  .featured-char-name {
    text-align: center;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-top: 6px;
    font-weight: bold;
    color: var(--color-text);
  }

  /* Credits */
  .credits-box {
    text-align: right;
    padding: 0 8px 16px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .credits-inner {
    display: inline-block;
    padding: 4px 12px;
    font-size: 13px;
    background: var(--color-scrollbox);
    border-radius: 20px;
    box-shadow: 4px 4px 0 rgba(var(--color-accent-rgb), 0.5);
  }
  .credits-inner a {
    color: var(--color-text);
    text-decoration: none;
    margin: 0 4px;
    transition: color 0.2s;
  }
  .credits-inner a:hover { color: var(--color-accent); }

  /* ===== CREATOR MODE ===== */
  #creator-mode {
    min-height: 100vh;
    background: #111;
    color: #eee;
    font-family: var(--font-body);
  }
  .creator-nav {
    background: #000;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(var(--color-accent-rgb), 0.4);
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .creator-nav h2 {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 5px;
    color: var(--color-accent);
    text-transform: uppercase;
  }
  .creator-nav .c-btns { display: flex; gap: 10px; }
  .c-btn {
    padding: 6px 18px;
    border-radius: 20px;
    border: 1px solid;
    font-family: var(--font-body);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .c-btn-save {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: #fff;
  }
  .c-btn-save:hover { opacity: 0.85; }
  .c-btn-exit {
    border-color: rgba(255,255,255,0.3);
    background: transparent;
    color: #ccc;
  }
  .c-btn-exit:hover { background: rgba(255,255,255,0.08); }

  .creator-layout {
    display: flex;
    height: calc(100vh - 57px);
  }

  /* Sidebar */
  .creator-sidebar {
    width: 320px;
    flex-shrink: 0;
    background: #1a1a1a;
    overflow-y: auto;
    border-right: 1px solid rgba(255,255,255,0.08);
    scrollbar-width: thin;
    scrollbar-color: #333 #1a1a1a;
  }
  .sidebar-section {
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .sidebar-section-title {
    padding: 12px 16px;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-accent);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
    background: #1a1a1a;
    position: sticky;
    top: 0;
    z-index: 5;
  }
  .sidebar-section-title:hover { background: #222; }
  .sidebar-section-title .toggle-arrow { transition: transform 0.2s; }
  .sidebar-section-title.collapsed .toggle-arrow { transform: rotate(-90deg); }
  .sidebar-body { padding: 12px 16px; }
  .sidebar-body.hidden { display: none; }

  /* Form fields */
  .field-group { margin-bottom: 14px; }
  .field-label {
    display: block;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 5px;
  }
  .field-input, .field-textarea, .field-select {
    width: 100%;
    background: #222;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    color: #eee;
    font-family: var(--font-body);
    font-size: 12px;
    padding: 7px 10px;
    transition: border-color 0.2s;
    outline: none;
  }
  .field-input:focus, .field-textarea:focus, .field-select:focus {
    border-color: var(--color-accent);
  }
  .field-textarea { resize: vertical; min-height: 70px; }
  .field-color {
    width: 40px;
    height: 32px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    cursor: pointer;
    background: #222;
    padding: 2px;
  }
  .color-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .color-row .field-input { flex: 1; }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  /* List editor */
  .list-editor { display: flex; flex-direction: column; gap: 6px; }
  .list-item-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .list-item-row .field-input { flex: 1; }
  .list-item-row .field-input.url-input { flex: 1.2; }
  .list-remove-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    color: #888;
    cursor: pointer;
    padding: 4px 8px;
    font-size: 12px;
    transition: all 0.2s;
  }
  .list-remove-btn:hover { background: rgba(255,60,60,0.2); border-color: #f66; color: #f99; }
  .list-add-btn {
    background: transparent;
    border: 1px dashed rgba(255,255,255,0.2);
    border-radius: 8px;
    color: #888;
    cursor: pointer;
    padding: 6px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: all 0.2s;
    width: 100%;
    margin-top: 4px;
  }
  .list-add-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }

  /* Preview pane */
  .creator-preview {
    flex: 1;
    overflow-y: auto;
    background: #0a0a0a;
    padding: 16px;
  }
  .preview-label {
    text-align: center;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 12px;
  }
  .preview-frame {
    background: #1a1a1a;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
  }

  /* Save notification */
  .save-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: var(--color-accent);
    color: #fff;
    padding: 10px 20px;
    border-radius: 20px;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s;
    pointer-events: none;
    z-index: 9999;
  }
  .save-toast.show { opacity: 1; transform: translateY(0); }

  /* Link style in viewer */
  .profile-outer a { color: var(--color-text); }

  /* Responsive */
  @media (max-width: 700px) {
    .creator-sidebar { width: 260px; }
    .left-col { width: 100%; max-width: 300px; }
  }
  @media (max-width: 500px) {
    .creator-layout { flex-direction: column; }
    .creator-sidebar { width: 100%; height: 50vh; }
    .creator-preview { height: 50vh; }
  }
</style>
</head>
<body>

<!-- ===== VIEWER MODE ===== -->
<div id="viewer-mode">

  <nav class="site-nav">
    <span class="nav-title" id="nav-site-title">My Profile</span>
    <div class="nav-links">
      <a href="#" class="nav-btn active" onclick="showSection('profile'); return false;">Profile</a>
      <a href="#" class="nav-btn" onclick="showSection('directory'); return false;">Directory</a>
      <a href="#" class="nav-btn" onclick="showSection('about'); return false;">About</a>
      <button class="nav-btn creator-trigger" onclick="openCreator()">✦ Creator Mode</button>
    </div>
  </nav>

  <div class="site-wrapper">

    <!-- Banner -->
    <div class="profile-banner no-image" id="profile-banner"></div>

    <div class="main-content" id="section-profile">

      <!-- Profile card outer -->
      <div class="profile-outer" id="profile-outer-bg">

        <div class="content-row">

          <!-- Left column -->
          <div class="left-col">
            <div class="left-inner" style="position:relative">
              <div class="left-icon-decor"><i class="fa-solid fa-cloud"></i></div>
              <div class="left-username" id="disp-username">username</div>
              <a class="left-pagedoll" id="disp-pagedoll-link" href="#">
                <img id="disp-pagedoll-img" src="" alt="" onerror="this.style.display='none'" style="display:none">
              </a>
              <div class="focal-image placeholder" id="disp-focal-image">[ focal image ]</div>
              <div class="left-info">
                <div id="disp-namepronouns">name, pro/nouns, birthday</div>
                <div class="icon-links" id="disp-icon-links"></div>
              </div>
            </div>
          </div>

          <!-- Right column -->
          <div class="right-col">
            <div class="right-inner">
