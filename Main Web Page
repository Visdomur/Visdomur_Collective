// ===== COLOR HELPERS =====
function syncColorHex(picker, hexId) {
  document.getElementById(hexId).value = picker.value;
}
function syncColorPicker(hexInput, pickerId) {
  const val = hexInput.value;
  if (/^#[0-9a-fA-F]{6}$/.test(val)) {
    document.getElementById(pickerId).value = val;
  }
}
function setColorField(pickerId, hexId, value) {
  document.getElementById(pickerId).value = value;
  document.getElementById(hexId).value = value;
}
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16)||217;
  const g = parseInt(hex.slice(3,5),16)||74;
  const b = parseInt(hex.slice(5,7),16)||121;
  return {r,g,b};
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escAttr(str) {
  return String(str||'').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

